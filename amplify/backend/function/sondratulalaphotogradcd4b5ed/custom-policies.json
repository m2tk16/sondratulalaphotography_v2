[
  {
    "Action": [
      "dynamodb:GetItem",
      "dynamodb:PutItem",
      "dynamodb:Scan"
    ],
    "Resource": [
      {
        "Fn::Sub": [
          "arn:aws:dynamodb:${AWS::Region}:${AWS::AccountId}:table/${TableName}",
          {
            "TableName": {
              "Fn::If": [
                "IsProduction",
                "SondraTulalaPhotography-PhotoLikes",
                {
                  "Fn::Join": [
                    "",
                    [
                      "SondraTulalaPhotography-PhotoLikes-",
                      {
                        "Ref": "env"
                      }
                    ]
                  ]
                }
              ]
            }
          }
        ]
      }
    ]
  },
  {
    "Action": [
      "s3:DeleteObject",
      "s3:GetObject",
      "s3:PutObject"
    ],
    "Resource": [
      {
        "Fn::Sub": [
          "arn:aws:s3:::${BucketName}/public/images/portfolio/*",
          {
            "BucketName": {
              "Ref": "storagesondratulalaphotographys3BucketName"
            }
          }
        ]
      }
    ]
  }
]
